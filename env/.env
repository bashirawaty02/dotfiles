###########################################################################################################################
# PATH Helpers (safe, portable)
###########################################################################################################################

prepend_path() {
    local dir="$1"
    [ -d "$dir" ] && PATH="$dir:$PATH"
}

append_path() {
    local dir="$1"
    [ -d "$dir" ] && PATH="$PATH:$dir"
}

# Core paths
prepend_path "/usr/local/bin"
prepend_path "/usr/local/sbin"
prepend_path "$HOME/bin"
prepend_path "$HOME/.secbin"
prepend_path "$HOME/.local/bin"
prepend_path "/usr/local/opt/ruby/bin"
prepend_path "$HOME/.neovim/bin"

append_path "$HOME/.neovim/node/bin"
append_path "$HOME/.emacs.d/bin"

###########################################################################################################################
# PYTHON
###########################################################################################################################

# Local Python libs
export PYTHONPATH="$HOME/python-libs${PYTHONPATH:+:$PYTHONPATH}"

# pyenv
if [ -d "$HOME/.pyenv" ]; then
    export PYENV_ROOT="$HOME/.pyenv"
    prepend_path "$PYENV_ROOT/bin"

    # Shell‑agnostic pyenv init
    if command -v pyenv >/dev/null; then
        eval "$(pyenv init --path)"
        eval "$(pyenv init -)"
    fi

    export PYENV_VIRTUALENV_DISABLE_PROMPT=1
fi

# Poetry
prepend_path "$HOME/.poetry/bin"

###########################################################################################################################
# DEFAULT COLORS / PROGRAMS
###########################################################################################################################

export CLICOLOR=1
export LSCOLORS="gxBxhxDxfxhxhxhxhxcxcx"

# Editor selection
if command -v nvim >/dev/null; then
    export EDITOR="nvim"
    export VISUAL="nvim"
else
    export EDITOR="vim"
    export VISUAL="vim"
fi

###########################################################################################################################
# Misc Software
###########################################################################################################################

# Go
export GOPATH="$HOME/go"
append_path "$GOPATH/bin"

# Rust
prepend_path "$HOME/.cargo/bin"

# Fasd
if command -v fasd >/dev/null; then
    eval "$(fasd --init auto)"
fi

# Ansible
export ANSIBLE_NOCOWS=1

# Broot
BROOT="$HOME/.config/broot/launcher/bash/br"
[ -f "$BROOT" ] && source "$BROOT"

# Disable telemetry for some tools
export ET_NO_TELEMETRY=1

###########################################################################################################################
# OS Specific
###########################################################################################################################

case "$(uname -s)" in
    Darwin)
        # asdf (brew)
        if command -v brew >/dev/null; then
            ASDF_ROOT="$(brew --prefix asdf 2>/dev/null)"
            [ -f "$ASDF_ROOT/asdf.sh" ] && source "$ASDF_ROOT/asdf.sh"
        fi
        ;;
    Linux)
        # Linux‑specific hooks can go here
        ;;
    CYGWIN*|MINGW32*|MSYS*)
        # Windows POSIX layer
        ;;
    *)
        # Unknown OS
        ;;
esac

###########################################################################################################################
# LOCAL ENV
###########################################################################################################################

[ -f "$HOME/.local-env" ] && source "$HOME/.local-env"
