#!/usr/bin/env zsh

### ─────────────────────────────────────────────
### Helper: alias only if command exists
### ─────────────────────────────────────────────
alias_if_exists() {
    local name="$1"
    local cmd="$2"
    if command -v "$cmd" >/dev/null 2>&1; then
        alias "$name"="$cmd"
    fi
}

### ─────────────────────────────────────────────
### Better defaults
### ─────────────────────────────────────────────
alias crontab="VIM_CRONTAB=true crontab"
alias_if_exists diff colordiff
alias_if_exists ag rg
alias_if_exists vim nvim
alias_if_exists fdupes jdupes

### ─────────────────────────────────────────────
### Navigation & Directory Shortcuts
### ─────────────────────────────────────────────
alias cl="clear"

if command -v exa >/dev/null; then
    alias ls="exa"
    alias l="exa -1"
    alias la="exa -a"
fi

mvr() { mv "$2" "$1"; }

alias cf='cd "$(fd -t d | fzf)"'

### ─────────────────────────────────────────────
### Git Shortcuts
### ─────────────────────────────────────────────
alias ga='git add'
alias gs='git status'
alias gu='git pull'
alias gg='git graph'
alias gd='git diff'
alias gsu='git stash && git pull && git stash pop'

ghostscript_path="/usr/local/bin/gs"
[ -x "$ghostscript_path" ] && alias ghostscript="$ghostscript_path"

gD() { git diff "$@" | ydiff; }

### ─────────────────────────────────────────────
### Jupyter
### ─────────────────────────────────────────────
alias jc="jupyter console"
alias jco="jupyter nbconvert"
alias jn="jupyter notebook"
alias jn-b="jupyter notebook --no-browser"

### ─────────────────────────────────────────────
### Media Downloading
### ─────────────────────────────────────────────
alias yt="yt-dlp"
alias yta="yt-dlp --extract-audio --audio-format mp3"
alias ytad="yt-dlp --extract-audio --audio-format mp3 --write-description --add-metadata --embed-thumbnail --write-info-json"
alias gdl="gallery-dl"

### ─────────────────────────────────────────────
### Misc
### ─────────────────────────────────────────────
alias my-ip="curl -s ipinfo.io/ip"
alias sr='screen -r'
alias sb='subl'
alias spell='aspell check --dont-backup'
alias grepc="grep -P --color=always"
alias printpath='echo $PATH | tr ":" "\n"'

alias sep='printf "%${COLUMNS}s\n" | tr " " "="'
alias rg="sep; rg -u"

alias clock='watch -n 0.1 '\''date +"%H:%M:%S" | toilet -f bigmono9'\'''

### ─────────────────────────────────────────────
### Terminal Title Helpers
### ─────────────────────────────────────────────
setTerminalText() {
    local mode="$1"; shift
    printf "\033]${mode};%s\007" "$*"
}

stt_both()  { setTerminalText 0 "$@"; }
stt_tab()   { setTerminalText 1 "$@"; }
stt_title() { setTerminalText 2 "$@"; }

tn() { stt_tab "$@" && tmux new -s "$@"; }
ta() { stt_tab "$@" && tmux a -t "$@"; }

### ─────────────────────────────────────────────
### Secret & Local Aliases
### ─────────────────────────────────────────────
[ -f ~/.secret-aliases ] && source ~/.secret-aliases
[ -f ~/.local-aliases ] && source ~/.local-aliases

### ─────────────────────────────────────────────
### Wormhole (snd/rcv)
### ─────────────────────────────────────────────
snd() {
    mkdir -p /tmp/passage
    cp "$1" /tmp/passage
    echo "$1" > /tmp/passage/last
}

rcv() {
    local file
    file=$(< /tmp/passage/last)
    cp -i "/tmp/passage/$file" "$file"
    rm "/tmp/passage/$file"
}

### ─────────────────────────────────────────────
### Docker: find container IP
### ─────────────────────────────────────────────
daddr() {
    docker network ls | tail -n +2 | awk '{print $2}' |
        xargs docker network inspect |
        jq --arg NAME "$1" '.[].Containers | .[] | select(.Name == $NAME) | .IPv4Address'
}

### ─────────────────────────────────────────────
### FZF Helpers
### ─────────────────────────────────────────────
if command -v fzf >/dev/null; then

    fh() {
        print -z "$(
            fc -l 1 |
            fzf +s --tac |
            sed 's/ *[0-9]* *//'
        )"
    }

    fkill() {
        local pid
        pid=$(ps -ef | sed 1d | fzf -m | awk '{print $2}')
        [[ -n "$pid" ]] && echo "$pid" | xargs kill -"${1:-9}"
    }

    v() {
        local file
        if [[ -f "$1" ]]; then
            vim "$1"
        else
            file="$(fasd -Rfl "$1" | fzf -1 -0 --no-sort +m)" &&
                vim "$file"
        fi
    }

    if command -v subl >/dev/null; then
        u() {
            local file
            file="$(fasd -Rfl "$1" | fzf -1 -0 --no-sort +m)" &&
                subl "$file"
        }
    fi

    fl() { less "$(fzf)"; }

fi

### ─────────────────────────────────────────────
### Ripgrep-all
### ─────────────────────────────────────────────
if command -v rga >/dev/null; then
    alias rgim="rga --rga-adapters=+tesseract -j4"

    rga-fzf() {
        local RG_PREFIX="rga --files-with-matches"
        local file
        file="$(
            FZF_DEFAULT_COMMAND="$RG_PREFIX '$1'" \
            fzf --sort \
                --preview="[[ -n {} ]] && rga --pretty --context 5 {q} {}" \
                --phony -q "$1" \
                --bind "change:reload:$RG_PREFIX {q}" \
                --preview-window="70%:wrap"
        )" &&
        xdg-open "$file"
    }
fi

### ─────────────────────────────────────────────
### Google autocomplete
### ─────────────────────────────────────────────
auto() {
    curl -sSG \
        -H 'user-agent: Mozilla/5.0' \
        --data-urlencode "q=$*" \
        'https://www.google.com/complete/search?client=hp&hl=en&xhr=t' |
        jq -r '.[1][][0]' |
        sed 's,</\?b>,,g'
}

### ─────────────────────────────────────────────
### OS-specific aliases
### ─────────────────────────────────────────────
case "$(uname -s)" in
    Darwin)
        alias clear-dnscache="dscacheutil -flushcache && sudo killall -HUP mDNSResponder"
        alias bu="brew update && brew outdated | xargs brew upgrade && brew cleanup -s --prune=0"

        alias chrome="/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome &"
        alias chromec="/Applications/Google\ Chrome\ Canary.app/Contents/MacOS/Google\ Chrome\ Canary &"

        alias fuck='eval $(thefuck $(fc -ln -1)); history -r'
        alias readlink="greadlink"

        alias mvf='mv "$(pfs)"'

        for i in awk cat chgrp chmod chown chroot cut date df du echo egrep env false fgrep find grep join kill link ln logname make mkdir mknod mktemp mv nice nohup paste perf printf pwd readlink realpath rm rmdir sed sort split tac tail tar tee test touch tr true truncate tty uniq unlink unzip uptime users who whoami yes zip; do
            alias_if_exists "$i" "g$i"
        done

        alias rm="grm -i"
        alias mv="gmv -i"
        alias cp="gcp -i"

        alias veracrypt="/Applications/VeraCrypt.app/Contents/MacOS/VeraCrypt --text"
        alias sudoedit="sudo -E vim"

        op() {
            local file
            if [[ -f "$1" ]]; then
                open "$1"
            else
                file="$(fasd -Rl "$1" | fzf -1 -0 --no-sort +m)" &&
                    open "$file"
            fi
        }
        ;;
    Linux)
        ;;
esac

### ─────────────────────────────────────────────
### Shell-dependent
### ─────────────────────────────────────────────
case $SHELL in
    */zsh) ;;
    */bash) ;;
esac
