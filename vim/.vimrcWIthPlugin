"──────────────────────────────────────────────
" BASIC
"──────────────────────────────────────────────
set nocompatible
set encoding=utf-8
set termguicolors
syntax on
filetype plugin indent on

let mapleader=" "

"──────────────────────────────────────────────
" PLUGINS (vim-plug)
"──────────────────────────────────────────────
call plug#begin('~/.vim/plugged')

" Core
Plug 'tpope/vim-sensible'
Plug 'ciaranm/securemodelines'
Plug 'editorconfig/editorconfig-vim'

" Search & Navigation
Plug 'romainl/vim-cool'
Plug 'haya14busa/incsearch.vim'
Plug 'junegunn/fzf', { 'dir': '~/.fzf', 'do': './install --all' }
Plug 'junegunn/fzf.vim'
Plug 'justinmk/vim-sneak'
Plug 'easymotion/vim-easymotion'
Plug 'haya14busa/incsearch-easymotion.vim'

" Editing
Plug 'tpope/vim-surround'
Plug 'tpope/vim-unimpaired'
Plug 'joom/vim-commentary'
Plug 'godlygeek/tabular'
Plug 'junegunn/vim-easy-align'
Plug 'foosoft/vim-argwrap'
Plug 'tpope/vim-repeat'
Plug 'tpope/vim-speeddating'
Plug 'terryma/vim-multiple-cursors'

" UI
Plug 'itchyny/lightline.vim'
Plug 'mhinz/vim-startify'
Plug 'scrooloose/nerdtree'
Plug 'simnalamburt/vim-mundo'
Plug 'majutsushi/tagbar'
Plug 'machakann/vim-highlightedyank'
Plug 'andymass/vim-matchup'
Plug 'kshenoy/vim-signature'
Plug 'yggdroot/indentline'
Plug 'tpope/vim-eunuch'
Plug 'aymericbeaumet/vim-symlink'
Plug 'moll/vim-bbye'

" Git
Plug 'airblade/vim-gitgutter'
Plug 'tpope/vim-fugitive'
Plug 'tpope/vim-rhubarb'
Plug 'junegunn/gv.vim'
Plug 'xuyuanp/nerdtree-git-plugin'
Plug 'tveskag/nvim-blame-line'

" Tmux
Plug 'tmux-plugins/vim-tmux-focus-events'
Plug 'roxma/vim-tmux-clipboard'
Plug 'christoomey/vim-tmux-navigator'

" Languages
Plug 'w0rp/ale'
Plug 'maximbaz/lightline-ale'
Plug 'plasticboy/vim-markdown'
Plug 'mzlogin/vim-markdown-toc'
Plug 'cespare/vim-toml'
Plug 'stephpy/vim-yaml'
Plug 'elzr/vim-json'
Plug 'rust-lang/rust.vim'
Plug 'glench/vim-jinja2-syntax'
Plug 'lervag/vimtex'
Plug 'pearofducks/ansible-vim'
Plug 'mechatroner/rainbow_csv'
Plug 'ap/vim-css-color'
Plug 'frazrepo/vim-rainbow'
Plug 'vim-pandoc/vim-pandoc'
Plug 'vim-pandoc/vim-pandoc-syntax'
Plug 'chrisbra/colorizer'
Plug 'vim-scripts/applescript.vim'
Plug 'pprovost/vim-ps1'
Plug 'fatih/vim-go', { 'do': ':GoUpdateBinaries' }
Plug 'mattn/emmet-vim'
Plug 'liuchengxu/vista.vim'
Plug 'vim-python/python-syntax'
Plug 'isobit/vim-caddyfile'

" Colorschemes
Plug 'morhetz/gruvbox'
Plug 'chriskempson/base16-vim'
Plug 'patstockwell/vim-monokai-tasty'
Plug 'sainnhe/sonokai'
Plug 'tanvirtin/monokai.nvim'
Plug 'srcery-colors/srcery-vim'

" Writing
Plug 'junegunn/goyo.vim'
Plug 'junegunn/limelight.vim'
Plug 'rhysd/vim-grammarous'
Plug 'ron89/thesaurus_query.vim'

" Other
Plug 'wakatime/vim-wakatime'
Plug 'ihsanturk/neuron.vim'
Plug 'liuchengxu/vim-which-key'
Plug 'iamcco/markdown-preview.nvim', { 'do': { -> mkdp#util#install() } }

" Completion
Plug 'neoclide/coc.nvim', {'branch': 'release'}

call plug#end()

"──────────────────────────────────────────────
" COLORS
"──────────────────────────────────────────────
if has('gui_running')
    colorscheme base16-gruvbox-dark-hard
elseif exists('+termguicolors')
    set termguicolors
    let &t_8f = "\<Esc>[38;2;%lu;%lu;%lum"
    let &t_8b = "\<Esc>[48;2;%lu;%lu;%lum"
    set background=dark
    colorscheme vim-monokai-tasty
else
    colorscheme molokai
endif

"──────────────────────────────────────────────
" INDENTATION
"──────────────────────────────────────────────
set tabstop=4
set softtabstop=4
set shiftwidth=4
set expandtab

"──────────────────────────────────────────────
" UI
"──────────────────────────────────────────────
set number relativenumber
set showcmd
set cursorline
set wildmenu
set showmatch
set laststatus=2
set mouse=a
set splitbelow splitright
set linebreak
set scrolloff=12
set updatetime=100
set ttyfast
set hidden

"──────────────────────────────────────────────
" SEARCH
"──────────────────────────────────────────────
set incsearch
set hlsearch
set ignorecase
set smartcase
nnoremap <C-h> :nohlsearch<CR>

"──────────────────────────────────────────────
" UNDO
"──────────────────────────────────────────────
set undofile
set undodir=~/.vim/undodir

"──────────────────────────────────────────────
" FOLDING
"──────────────────────────────────────────────
set foldenable
set foldlevelstart=10
set foldnestmax=10
set foldmethod=indent

"──────────────────────────────────────────────
" MOVEMENT
"──────────────────────────────────────────────
nnoremap j gj
nnoremap k gk
nnoremap gV `[v`]
nnoremap H ^
nnoremap L $

"──────────────────────────────────────────────
" CUSTOM FUNCTIONS
"──────────────────────────────────────────────
function! ToggleLineNumber()
    if &relativenumber
        set norelativenumber number
    else
        set relativenumber
    endif
endfunction

function! ToggleALEFix()
    let g:ale_fix_on_save = !g:ale_fix_on_save
endfunction

function! ToggleColorColumn()
    if &colorcolumn == ''
        set colorcolumn=88
    else
        set colorcolumn=
    endif
endfunction

function! ToggleZoom(toggle)
  if exists("t:restore_zoom") && (t:restore_zoom.win != winnr() || a:toggle)
      exec t:restore_zoom.cmd
      unlet t:restore_zoom
  elseif a:toggle
      let t:restore_zoom = { 'win': winnr(), 'cmd': winrestcmd() }
      vert resize | resize
  endif
endfunction

"──────────────────────────────────────────────
" AUTOCOMMANDS
"──────────────────────────────────────────────
autocmd BufRead *.orig set readonly
autocmd BufRead *.bk set readonly

autocmd BufReadPost * if expand('%:p') !~# '\m/\.git/' && line("'\"") > 1 && line("'\"") <= line("$") | exe "normal! g'\"" | endif

autocmd BufRead *.plot set filetype=gnuplot
autocmd BufRead *.md set filetype=markdown
autocmd BufRead *.tex set filetype=tex
autocmd BufRead *.rss set filetype=xml

autocmd BufNewFile,BufRead *.yml.j2 set syntax=yaml

"──────────────────────────────────────────────
" LOCAL CONFIG
"──────────────────────────────────────────────
if filereadable(expand("~/.vimrc_local"))
    source ~/.vimrc_local
endif
